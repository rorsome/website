{
    "name": "website",
    "compatibility_date": "2026-03-24",
    "assets": {
        "directory": "./_site",
        "html_handling": "auto-trailing-slash",
        "not_found_handling": "single-page-application"
    },
    "placement": {
        "mode": "smart"
    },
    "routes": [
        {
            "pattern": "rorylawless.com",
            "custom_domain": true
        }
    ]
}
